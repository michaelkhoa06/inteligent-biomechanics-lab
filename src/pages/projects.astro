                            <path d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>
                        </svg>
                    </div>
                    <h3 class="tech-title">AI Acceleration</h3>
                    <p class="tech-text">Graph neural network-based surrogate modeling extending HeartSimSage technology.</p>
                </div>
                <div class="tech-card">
