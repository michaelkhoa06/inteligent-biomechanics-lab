        const contents = document.querySelectorAll('.project-content');
        
        tabs.forEach(tab => {
            tab.addEventListener('click', function() {
                const targetTab = this.getAttribute('data-tab');
                
                tabs.forEach(t => t.classList.remove('cs-tab-active'));
                contents.forEach(c => c.classList.remove('project-active'));
                
                this.classList.add('cs-tab-active');
                document.getElementById(targetTab + '-content').classList.add('project-active');
            });
        });
    });
</script>