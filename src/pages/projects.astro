    <!-- Architecture -->
    <section class="item-section">
        <div class="cs-container">
            <h2 class="section-title">Technical Architecture</h2>
            <p class="section-text">The Stomach Digital Twin integrates three core technical pillars: microstructure-informed biomechanical modeling, electromechanical coupling, and AI-accelerated simulation.</p>

            <div class="tech-grid">
                <div class="tech-card">
                    <div class="tech-icon">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M4 12h16M4 12l4-4m-4 4l4 4"/>
                            <circle cx="12" cy="12" r="3"/>
                        </svg>
                    </div>
                    <h3 class="tech-title">Hyper-Viscoelastic Modeling</h3>
                    <p class="tech-text">Microstructure-informed material model capturing soft tissue tensile behavior across large deformations.</p>
                </div>
                <div class="tech-card">
                    <div class="tech-icon">
                        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="M12 22c5.523 0 10-4.477 10-10S17.523 2 12 2 2 6.477 2 12s4.477 10 10 10z"/>
                            <path d="M9 12l2 2 4-4"/>
                        </svg>
                    </div>
                    <h3 class="tech-title">Electromechanical Coupling</h3>
                    <p class="tech-text">3D-0D implicit coupling framework integrating ion-based electrophysiology with solid mechanics.</p>
                </div>
                <div class="tech-card">
