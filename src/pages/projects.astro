        </div>
    </section>

    <!-- Timeline -->
    <section class="item-section bg-dark">
        <div class="cs-container">
            <h2 class="section-title light">Project Timeline</h2>
            <p class="section-text light">Key milestones and achievements throughout the project lifecycle.</p>
            
            <div class="timeline">
                <div class="timeline-item">
                    <div class="timeline-marker"></div>
