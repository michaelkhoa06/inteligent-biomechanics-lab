<style>
@keyframes float {
    0%, 100% { transform: translateY(0px) rotate(0deg); }
    50% { transform: translateY(-20px) rotate(5deg); }
}

@keyframes twinkle {
    0%, 100% { opacity: 0.3; transform: scale(1); }
    50% { opacity: 1; transform: scale(1.2); }
}

@keyframes floatSlow {
    0%, 100% { transform: translateY(0px) rotate(0deg); }
    50% { transform: translateY(-30px) rotate(10deg); }
}

@keyframes rotate {
    0% { transform: rotate(0deg); }
    100% { transform: rotate(360deg); }
}

#meet-team-1435 {
    padding-top: 8rem;
    padding-bottom: var(--sectionPadding);
    position: relative;
    overflow: hidden;
}

#meet-team-1435 .cs-container {
    width: 100%;
    max-width: 56.5rem;
    margin: auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: clamp(3rem, 6vw, 4rem);
    position: relative;
    z-index: 2;
}

#meet-team-1435 .cs-background-gradient {
    position: absolute;
    top: -10%;
    left: -10%;
    right: -10%;
    height: 40%;
    background: linear-gradient(135deg, rgba(255, 107, 107, 0.1) 0%, rgba(78, 205, 196, 0.1) 50%, rgba(255, 128, 255, 0.1) 100%);
    border-radius: 0 0 50% 50%;
    z-index: 0;
}

#meet-team-1435 .cs-grid-background {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 300px;
    background-image: 
        linear-gradient(rgba(78, 205, 196, 0.05) 1px, transparent 1px),
        linear-gradient(90deg, rgba(78, 205, 196, 0.05) 1px, transparent 1px);
    background-size: 50px 50px;
    z-index: 0;
}

#meet-team-1435 .cs-content {
    text-align: center;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    position: relative;
    z-index: 2;
}

#meet-team-1435 .cs-header-decoration {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 300px;
    pointer-events: none;
    overflow: hidden;
    z-index: 1;
}

#meet-team-1435 .cs-decoration-circle {
    position: absolute;
    border-radius: 50%;
    opacity: 0.5;
    animation: float 6s ease-in-out infinite;
}

#meet-team-1435 .cs-circle-1 {
    width: 80px;
    height: 80px;
    background: linear-gradient(135deg, #FF6B6B, #FFE66D);
    top: 20px;
    left: 5%;
    animation-delay: 0s;
    box-shadow: 0 0 30px rgba(255, 107, 107, 0.4);
}

#meet-team-1435 .cs-circle-2 {
    width: 60px;
    height: 60px;
    background: linear-gradient(135deg, #4ECDC4, #44A08D);
    top: 100px;
    right: 10%;
    animation-delay: 2s;
    box-shadow: 0 0 25px rgba(78, 205, 196, 0.4);
}

#meet-team-1435 .cs-circle-3 {
    width: 40px;
    height: 40px;
    background: linear-gradient(135deg, #FF80FF, #FF69B4);
    top: 150px;
    left: 20%;
    animation-delay: 4s;
    box-shadow: 0 0 20px rgba(255, 128, 255, 0.4);
}

#meet-team-1435 .cs-circle-4 {
    width: 50px;
    height: 50px;
    background: linear-gradient(135deg, #45B7D1, #2980B9);
    top: 60px;
    right: 30%;
    animation-delay: 1s;
    animation: floatSlow 8s ease-in-out infinite;
    box-shadow: 0 0 25px rgba(69, 183, 209, 0.4);
}

#meet-team-1435 .cs-circle-5 {
    width: 30px;
    height: 30px;
    background: linear-gradient(135deg, #9B59B6, #8E44AD);
    top: 180px;
    right: 5%;
    animation-delay: 3s;
    animation: floatSlow 10s ease-in-out infinite;
    box-shadow: 0 0 15px rgba(155, 89, 182, 0.4);
}

#meet-team-1435 .cs-decoration-star {
    position: absolute;
    font-size: 28px;
    animation: twinkle 3s ease-in-out infinite;
}

#meet-team-1435 .cs-star-1 {
    top: 30px;
    right: 25%;
    animation-delay: 0s;
}

#meet-team-1435 .cs-star-2 {
    top: 120px;
    left: 15%;
    animation-delay: 1.5s;
}

#meet-team-1435 .cs-star-3 {
    top: 80px;
    left: 60%;
    animation-delay: 2.5s;
    font-size: 32px;
}

#meet-team-1435 .cs-decoration-square {
    position: absolute;
    width: 35px;
    height: 35px;
    opacity: 0.4;
    animation: rotate 15s linear infinite;
}

#meet-team-1435 .cs-square-1 {
    background: linear-gradient(135deg, #FF6B6B, transparent);
    top: 50px;
    left: 5%;
    animation-delay: 0s;
}

#meet-team-1435 .cs-square-2 {
    background: linear-gradient(135deg, #4ECDC4, transparent);
    top: 160px;
    right: 20%;
    animation-delay: 5s;
}

#meet-team-1435 .cs-decoration-triangle {
    position: absolute;
    width: 0;
    height: 0;
    opacity: 0.4;
    animation: floatSlow 7s ease-in-out infinite;
}

#meet-team-1435 .cs-triangle-1 {
    border-left: 25px solid transparent;
    border-right: 25px solid transparent;
    border-bottom: 43px solid #FFE66D;
    top: 140px;
    left: 70%;
