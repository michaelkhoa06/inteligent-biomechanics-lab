<style lang="less">

    
/* Mobile */
@media only screen and (min-width: 0rem) {
    #meet-team-1435 {
        padding-top: 8rem;
        padding-bottom: var(--sectionPadding);

        .cs-container {
            width: 100%;
            max-width: (904/16rem);
            margin: auto;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: clamp(3rem, 6vw, 4rem);
        }

        .cs-content {
            text-align: center;
            width: 100%;
            display: flex;
            flex-direction: column;
            align-items: center;
        }

        .cs-card-group {
            width: 100%;
            max-width: (413/16rem);
            margin: 0;
            padding: 0;
            display: grid;
            grid-template-columns: repeat(12, 1fr);
            gap: clamp(1rem, 1.8vw, 1.25rem);
            position: relative;
        }

        .cs-item {
            list-style: none;
            width: 100%;
            border: 1px solid #e8e8e8;
            border-radius: (16/16rem);
            display: flex;
            flex-direction: column;
            justify-content: flex-end;
            align-items: center;
            grid-column: span 12;
            position: relative;
            overflow: hidden;
        }

        .cs-picture {
            width: 100%;
            display: block;
            position: relative;
            z-index: 1;
            aspect-ratio: ~"305 / 338";
            min-height: 0;

            img {
                width: 100%;
                height: 100%;
                object-fit: cover;
                object-position: top;
                position: absolute;
                top: 0;
                left: 0;
            }
        }

        .cs-info {
            text-align: center;
            width: 100%;
            box-sizing: border-box;
            padding: (24/16rem);
            display: flex;
            flex-direction: column;
            align-items: center;
            position: relative;
            z-index: 10;
        }

        .cs-name {
            font-size: (20/16rem);
            font-weight: 700;
            line-height: 1.2em;
            margin: 0 0 (4/16rem) 0;
            color: var(--headerColor);
            display: block;
            transition: color 0.3s;
        }

        .cs-job {
            font-size: (16/16rem);
            line-height: 1.5em;
            margin: 0 0 (16/16rem) 0;
            color: var(--bodyTextColor);
            display: block;
        }

        .cs-bio-button {
            font-size: (14/16rem);
            font-weight: 700;
            line-height: 1.2em;
            padding: (10/16rem) (18/16rem);
            border: 1px solid #d9d9d9;
            border-radius: (8/16rem);
            background-color: #f7f7f7;
            color: var(--headerColor);
            cursor: pointer;
            transition: background-color 0.3s, border-color 0.3s, color 0.3s;
            text-decoration: none;

            &:hover {
                background-color: var(--primary);
                border-color: var(--primary);
                color: #fff;
            }
        }

        .cs-member-bio {
            display: none;
        }
    }

    .cs-modal-overlay {
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, 0.55);
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 1.5rem;
        z-index: 9999;
        opacity: 0;
        visibility: hidden;
        pointer-events: none;
        transition: opacity 0.25s ease, visibility 0.25s ease;
    }

    .cs-modal-overlay.cs-active {
        opacity: 1;
        visibility: visible;
        pointer-events: auto;
    }

    .cs-modal {
        width: min(90vw, 48rem);
        max-height: 85vh;
        overflow-y: auto;
        background: #fff;
        border-radius: (18/16rem);
        box-shadow: 0 20px 60px rgba(0, 0, 0, 0.25);
        padding: (32/16rem);
        position: relative;
        box-sizing: border-box;
    }

    .cs-modal-close {
        width: (40/16rem);
        height: (40/16rem);
        border: none;
        border-radius: 50%;
        background: #f1f1f1;
        color: #333;
        font-size: (24/16rem);
        line-height: 1;
        cursor: pointer;
        position: absolute;
        top: (16/16rem);
        right: (16/16rem);
        display: flex;
        justify-content: center;
        align-items: center;
        transition: background-color 0.3s, color 0.3s;

        &:hover {
            background-color: #ddd;
            color: #000;
        }
    }

    .cs-modal-header {
        padding-right: 3rem;
        margin-bottom: (20/16rem);
    }

    .cs-modal-name {
        font-size: clamp(1.75rem, 3vw, 2.25rem);
        line-height: 1.2em;
        font-weight: 700;
        margin: 0 0 (8/16rem) 0;
        color: var(--headerColor);
    }

    .cs-modal-job {
        font-size: (18/16rem);
        line-height: 1.5em;
        margin: 0;
        color: var(--primary);
        font-weight: 600;
    }

    .cs-modal-body {
        font-size: (16/16rem);
        line-height: 1.7em;
        color: var(--bodyTextColor);
    }

    .cs-modal-body p {
        margin: 0 0 1rem 0;
    }

    .cs-modal-body p:last-child {
        margin-bottom: 0;
    }
}

@media only screen and (min-width: 48rem) {
    #meet-team-1435 {
        .cs-card-group {
            max-width: 100%;
            align-items: stretch;
        }

        .cs-item {
            max-width: 100%;
            grid-column: span 6;
            transition: box-shadow 0.3s;

            &:hover {
                box-shadow: 0px 4px 120px 0px rgba(0, 0, 0, 0.12);

                .cs-name {
                    color: var(--primary);
                }
            }
        }

        .cs-picture {
            height: 100%;
            min-height: clamp(17.5rem, 33vw, 21.875rem);
            background-color: #000;
            overflow: hidden;
            aspect-ratio: initial;

            img {
                transition: transform 0.6s, opacity 0.3s;
            }
        }
    }
}

@media only screen and (min-width: 81.25rem) {
    #meet-team-1435 {
        .cs-container {
            max-width: (1280/16rem);
        }

        .cs-item {
            grid-column: span 3;
        }

        .cs-picture {
            height: clamp(15.3125rem, 27vw, 21.125rem);
            min-height: (245/16rem);
        }
    }
}

:global(body.cs-modal-open) {
    overflow: hidden;
}
</style>
                                                     

                                
                                
</style>

<script is:inline>
    const modalOverlay = document.getElementById("memberModalOverlay");
    const modalClose = document.getElementById("memberModalClose");
    const modalName = document.getElementById("cs-modal-name");
    const modalJob = document.getElementById("cs-modal-job");
    const modalBody = document.getElementById("cs-modal-body");

    function openMemberModal(card) {
        const name = card.querySelector(".cs-name")?.textContent?.trim() || "";
        const job = card.querySelector(".cs-job")?.textContent?.trim() || "";
        const bio = card.querySelector(".cs-member-bio")?.innerHTML || "";

        modalName.textContent = name;
        modalJob.textContent = job;
        modalBody.innerHTML = bio;

        modalOverlay.classList.add("cs-active");
        modalOverlay.setAttribute("aria-hidden", "false");
        document.body.classList.add("cs-modal-open");
    }

    function closeMemberModal() {
        modalOverlay.classList.remove("cs-active");
        modalOverlay.setAttribute("aria-hidden", "true");
        document.body.classList.remove("cs-modal-open");
    }

    document.addEventListener("click", (event) => {
        const openButton = event.target.closest(".js-open-bio");

        if (openButton) {
            const card = openButton.closest(".cs-item");
            if (card) openMemberModal(card);
        }

        if (event.target === modalOverlay || event.target.closest("#memberModalClose")) {
            closeMemberModal();
        }
    });

    document.addEventListener("keydown", (event) => {
        if (event.key === "Escape" && modalOverlay.classList.contains("cs-active")) {
            closeMemberModal();
        }
    });
</script>