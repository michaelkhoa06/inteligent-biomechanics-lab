                    <span class="cs-tag">Cardiac Digital Twin</span>
                    <span class="cs-tag">Multiscale Modeling</span>
                    <span class="cs-tag">CFD</span>
                    <span class="cs-tag">Electromechanics</span>
                    <span class="cs-tag">Personalization</span>
                </div>
            </div>
        </div>

        <!-- Category 2: Computational Biomechanics -->
        <div class="cs-category-card cs-card-biomechanics">
            <div class="cs-category-header">
                <div class="cs-category-icon">🧬</div>
                <div class="cs-category-info">
                    <h2 class="cs-category-title">Computational Biomechanics & Tissue Modeling</h2>
                    <span class="cs-category-badge">Tissue Mechanics</span>
                </div>
            </div>
            <div class="cs-category-image">
                <img src="/assets/images/achievements/computationalbiomechanics.jpg" alt="Tissue Modeling" loading="lazy">
            </div>
            <div class="cs-section">
                <h3 class="cs-section-title">
                    <span class="cs-section-icon">📌</span> Project Focus
                </h3>
                <p class="cs-section-content">
                    Mechanical characterization and constitutive modeling of biological tissues
                </p>
            </div>
            <div class="cs-section">
                <h3 class="cs-section-title">
                    <span class="cs-section-icon">📄</span> Papers
                </h3>
                <ul class="cs-paper-list">
                    <li class="cs-paper-item">
                        <a href="https://pubmed.ncbi.nlm.nih.gov/41307006/" target="_blank" rel="noopener" class="cs-paper-link">
                            Microstructure-Informed Hyper-Viscoelastic Model Capturing Soft Tissue Tensile Behavior (2026, JMPS)
                            <span class="cs-link-icon">↗</span>
                        </a>
                    </li>
                    <li class="cs-paper-item">
                        <a href="https://scholar.google.com/scholar?q=Finite+Porous+Viscoelastic+Model+Human+Cervix+Shi" target="_blank" rel="noopener" class="cs-paper-link">
                            Finite Porous-Viscoelastic Model for Human Cervix (2023, JMBM)
                            <span class="cs-link-icon">↗</span>
                        </a>
                    </li>
                    <li class="cs-paper-item">
                        <a href="https://scholar.google.com/scholar?q=Three-dimensional+anisotropic+hyperelastic+cervix+Shi" target="_blank" rel="noopener" class="cs-paper-link">
                            3D Anisotropic Hyperelastic Model for Cervix (2022, Acta Biomaterialia)
                            <span class="cs-link-icon">↗</span>
                        </a>
                    </li>
                    <li class="cs-paper-item">
                        <a href="https://scholar.google.com/scholar?q=Equilibrium+Mechanical+Properties+Human+Uterus+Shi" target="_blank" rel="noopener" class="cs-paper-link">
                            Equilibrium Mechanical Properties of the Human Uterus (2025, Acta Biomaterialia)
                            <span class="cs-link-icon">↗</span>
                        </a>
                    </li>
                    <li class="cs-paper-item">
                        <a href="https://scholar.google.com/scholar?q=Nonhuman+Primate+Cervix+Mechanical+Properties+Shi" target="_blank" rel="noopener" class="cs-paper-link">
                            Equilibrium Mechanical Properties of Nonhuman Primate Cervix (2024, JBE)
                            <span class="cs-link-icon">↗</span>
                        </a>
                    </li>
                    <li class="cs-paper-item">
                        <a href="https://scholar.google.com/scholar?q=Anisotropic+Mechanical+Properties+Human+Cervix+Shi" target="_blank" rel="noopener" class="cs-paper-link">
                            Anisotropic Mechanical Properties of Human Cervix (2019, JBE)
                            <span class="cs-link-icon">↗</span>
                        </a>
                    </li>
                </ul>
            </div>
            <div class="cs-section">
                <h3 class="cs-section-title">
                    <span class="cs-section-icon">🎯</span> Keywords
                </h3>
                <div class="cs-tags">
                    <span class="cs-tag">Biomechanics</span>
                    <span class="cs-tag">Hyperelasticity</span>
                    <span class="cs-tag">Viscoelasticity</span>
                    <span class="cs-tag">FEM</span>
                    <span class="cs-tag">Experimental Modeling</span>
                </div>
            </div>
        </div>

        <!-- Category 3: Simulation Framework -->
        <div class="cs-category-card cs-card-simulation">
            <div class="cs-category-header">
                <div class="cs-category-icon">⚙️</div>
                <div class="cs-category-info">
                    <h2 class="cs-category-title">Simulation Framework & Numerical Methods</h2>
                    <span class="cs-category-badge">Simulation Systems</span>
                </div>
            </div>
            <div class="cs-category-image">
                <img src="/assets/images/achievements/simulationmethods.png" alt="Simulation Framework" loading="lazy">
            </div>
            <div class="cs-section">
                <h3 class="cs-section-title">
                    <span class="cs-section-icon">📌</span> Project Focus
                </h3>
                <p class="cs-section-content">
                    Simulation infrastructure, coupling methods, and computational frameworks
                </p>
            </div>
            <div class="cs-section">
                <h3 class="cs-section-title">
                    <span class="cs-section-icon">📄</span> Papers
                </h3>
                <ul class="cs-paper-list">
                    <li class="cs-paper-item">
                        <a href="https://scholar.google.com/scholar?q=Implicit+3D+0D+Coupling+Cardiac+Mechanics" target="_blank" rel="noopener" class="cs-paper-link">
                            A Modular Framework for Implicit 3D–0D Coupling in Cardiac Mechanics (2024, CMAME)
                            <span class="cs-link-icon">↗</span>
                        </a>
                    </li>
                    <li class="cs-paper-item">
                        <a href="https://www.sciencedirect.com/science/article/pii/S0045782524007394" target="_blank" rel="noopener" class="cs-paper-link">
                            A Software Benchmark for Cardiac Elastodynamics (2025, CMAME)
                            <span class="cs-link-icon">↗</span>
                        </a>
                    </li>
                    <li class="cs-paper-item">
                        <a href="https://scholar.google.com/scholar?q=Optimization+Framework+Cardiac+Mechanics+Shi" target="_blank" rel="noopener" class="cs-paper-link">
                            An Optimization Framework to Personalize Passive Cardiac Mechanics (2024, CMAME)
                            <span class="cs-link-icon">↗</span>
                        </a>
                    </li>
                    <li class="cs-paper-item">
                        <a href="https://scholar.google.com/scholar?q=HeartsimSAGE+graph+neural+networks+cardiac+Shi" target="_blank" rel="noopener" class="cs-paper-link">
                            HeartsimSAGE: Attention-Enhanced Graph Neural Networks for Cardiac Mechanics Acceleration (2026, JCP)
                            <span class="cs-link-icon">↗</span>
                        </a>
                    </li>
                </ul>
            </div>
            <div class="cs-section">
                <h3 class="cs-section-title">
                    <span class="cs-section-icon">🎯</span> Keywords
                </h3>
                <div class="cs-tags">
                    <span class="cs-tag">Simulation Framework</span>
                    <span class="cs-tag">Multiphysics Coupling</span>
                    <span class="cs-tag">Optimization</span>
                    <span class="cs-tag">Acceleration</span>
                </div>
            </div>
        </div>

        <!-- Category 4: AI & Machine Learning -->
        <div class="cs-category-card cs-card-ai">
            <div class="cs-category-header">
                <div class="cs-category-icon">🤖</div>
                <div class="cs-category-info">
                    <h2 class="cs-category-title">AI & Machine Learning</h2>
                    <span class="cs-category-badge">Emerging Direction</span>
                </div>
            </div>
            <div class="cs-category-image">
                <img src="/assets/images/achievements/ml.png" alt="AI & Machine Learning" loading="lazy">
            </div>
            <div class="cs-section">
                <h3 class="cs-section-title">
                    <span class="cs-section-icon">📌</span> Project Focus
                </h3>
                <p class="cs-section-content">
                    Machine learning methods for simulation acceleration and generative modeling
                </p>
            </div>
            <div class="cs-section">
                <h3 class="cs-section-title">
                    <span class="cs-section-icon">📄</span> Papers
                </h3>
                <ul class="cs-paper-list">
                    <li class="cs-paper-item">
                        <a href="https://arxiv.org/abs/2504.18968" target="_blank" rel="noopener" class="cs-paper-link">
                            HeartsimSAGE: Attention-Enhanced Graph Neural Networks for Cardiac Mechanics (2026, JCP) ⭐
                            <span class="cs-link-icon">↗</span>
                        </a>
                    </li>
                    <li class="cs-paper-item">
                        <a href="https://scholar.google.com/scholar?q=Variance-Aware+Adaptive+Weighting+Diffusion+Model+Shi" target="_blank" rel="noopener" class="cs-paper-link">
                            Variance-Aware Adaptive Weighting for Diffusion Model Training (2026, arXiv)
                            <span class="cs-link-icon">↗</span>
                        </a>
                    </li>
                </ul>
            </div>
            <div class="cs-section">
                <h3 class="cs-section-title">
                    <span class="cs-section-icon">🎯</span> Keywords
                </h3>
                <div class="cs-tags">
                    <span class="cs-tag">GNN</span>
                    <span class="cs-tag">Diffusion Models</span>
                    <span class="cs-tag">Surrogate Modeling</span>
                    <span class="cs-tag">AI for Physics</span>
                </div>
            </div>
        </div>

        

        <!-- Google Scholar Link -->
        <div class="cs-scholar-section">
            <a href="https://scholar.google.com/citations?user=t-lHPeMAAAAJ&hl=en" target="_blank" rel="noopener" class="cs-scholar-link">
                <span class="cs-scholar-icon">📚</span>
                <span class="cs-scholar-text">View full list on Google Scholar</span>
                <span class="cs-scholar-arrow">→</span>
            </a>
        </div>
    </div>
</section>
                                                                                                                      

<style lang="less">
/*-- -------------------------- -->
<---        Research Categories  -->
<--- -------------------------- -*/

@keyframes fadeInUp {
    from {
        opacity: 0;
        transform: translateY(30px);
    }
    to {
        opacity: 1;
        transform: translateY(0);
    }
}

@keyframes shimmer {
    0% {
        background-position: -200% 0;
    }
    100% {
        background-position: 200% 0;
    }
}

#research-categories {
    padding: var(--sectionPadding);
    background: linear-gradient(180deg, #fafbfc 0%, #ffffff 100%);
    position: relative;
    overflow: hidden;

    &::before {
        content: '';
        position: absolute;
        top: -20%;
        right: -10%;
        width: 60%;
        height: 60%;
        background: radial-gradient(circle, rgba(78, 205, 196, 0.1) 0%, transparent 70%);
        border-radius: 50%;
        pointer-events: none;
    }

    &::after {
        content: '';
        position: absolute;
        bottom: -10%;
        left: -10%;
        width: 50%;
        height: 50%;
        background: radial-gradient(circle, rgba(255, 107, 107, 0.08) 0%, transparent 70%);
        border-radius: 50%;
        pointer-events: none;
    }

    .cs-container {
        max-width: 75rem;
        margin: 0 auto;
        position: relative;
        z-index: 2;
    }

    .cs-header {
        text-align: center;
        margin-bottom: 3.5rem;

        .cs-main-title {
            font-size: clamp(2rem, 5vw, 3rem);
            font-weight: 800;
            color: var(--headerColor);
            margin: 0 0 1rem 0;
            background: linear-gradient(135deg, var(--primary) 0%, #4ECDC4 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            background-clip: text;
        }

        .cs-main-subtitle {
            font-size: 1.125rem;
            color: var(--bodyTextColor);
            opacity: 0.85;
            max-width: 35rem;
            margin: 0 auto;
        }
    }

    .cs-category-card {
        background: #fff;
        border-radius: 1.5rem;
        overflow: hidden;
        box-shadow: 0 4px 25px rgba(0, 0, 0, 0.08);
        margin-bottom: 2rem;
        animation: fadeInUp 0.6s ease forwards;
        opacity: 0;
        transition: all 0.35s ease;

        &:hover {
            transform: translateY(-5px);
            box-shadow: 0 12px 40px rgba(0, 0, 0, 0.12);
        }

        &:nth-child(2) { animation-delay: 0.1s; }
        &:nth-child(3) { animation-delay: 0.2s; }
        &:nth-child(4) { animation-delay: 0.3s; }
        &:nth-child(5) { animation-delay: 0.4s; }
        &:nth-child(6) { animation-delay: 0.5s; }
    }

    .cs-card-cardiac {
        border-top: 4px solid #FF6B6B;
        .cs-category-badge { background: rgba(255, 107, 107, 0.15); color: #FF6B6B; }
        .cs-tag { background: rgba(255, 107, 107, 0.1); color: #FF6B6B; }
    }

    .cs-card-biomechanics {
        border-top: 4px solid #4ECDC4;
        .cs-category-badge { background: rgba(78, 205, 196, 0.15); color: #4ECDC4; }
        .cs-tag { background: rgba(78, 205, 196, 0.1); color: #4ECDC4; }
    }

    .cs-card-simulation {
        border-top: 4px solid #45B7D1;
        .cs-category-badge { background: rgba(69, 183, 209, 0.15); color: #45B7D1; }
        .cs-tag { background: rgba(69, 183, 209, 0.1); color: #45B7D1; }
    }

    .cs-card-ai {
        border-top: 4px solid #9B59B6;
        .cs-category-badge { background: rgba(155, 89, 182, 0.15); color: #9B59B6; }
        .cs-tag { background: rgba(155, 89, 182, 0.1); color: #9B59B6; }
    }

    .cs-card-materials {
        border-top: 4px solid #F39C12;
        .cs-category-badge { background: rgba(243, 156, 18, 0.15); color: #F39C12; }
        .cs-tag { background: rgba(243, 156, 18, 0.1); color: #F39C12; }
    }

    .cs-category-header {
        display: flex;
        align-items: center;
        gap: 1.25rem;
        padding: 1.5rem;
        background: linear-gradient(135deg, rgba(0, 0, 0, 0.02) 0%, transparent 100%);
    }

    .cs-category-icon {
        font-size: 2.5rem;
        flex-shrink: 0;
    }

    .cs-category-info {
        flex: 1;

        .cs-category-title {
            font-size: 1.25rem;
            font-weight: 700;
            color: var(--headerColor);
            margin: 0 0 0.375rem 0;
        }

        .cs-category-badge {
            font-size: 0.75rem;
            font-weight: 600;
            padding: 0.25rem 0.75rem;
            border-radius: 9999px;
            text-transform: uppercase;
