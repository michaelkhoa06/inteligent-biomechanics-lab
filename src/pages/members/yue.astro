---
import BaseLayout from "src/layouts/BaseLayout.astro";

const member = {
  fullName: "Yue Li",
  role: "Graduate Assistant",
  image: "/assets/images/members/lydia.png",
  email: "lydia@example.com",
  department: "Intelligent Biomechanics Lab",
  shortBio:
    "Lydia Yue is a graduate student in the Intelligent Biomechanics Lab, where she contributes to interdisciplinary research at the intersection of biomechanics, computation, and experimental analysis.",

  introduction: 
    "Lydia Yue is a graduate student in the Intelligent Biomechanics Lab, where she contributes to interdisciplinary research at the intersection of biomechanics, computation, and experimental analysis.",

  academicExperience: [
    "Ph.D. in [Field] - [University]",
    "M.S. in [Field] - [University]",
    "B.S. in [Field] - [University]"
  ],

  workExperience: [
    "Researcher, Kennesaw State University",
    "Previous Position - Institution / Organization",
    "Previous Position - Institution / Organization"
  ],

  cvSections: [
    {
      title: "Research Interests",
      items: [
        "Gastrointestinal biomechanics",
        "Digital twin development",
        "Computational modeling",
        "Experimental biomechanics"
      ]
    },
    {
      title: "Selected Projects",
      items: [
        "Project title or short description",
        "Project title or short description",
        "Project title or short description"
      ]
    },
    {
      title: "Awards / Honors",
      items: [
        "Award or recognition",
        "Award or recognition"
      ]
    }
  ],

  locations: {
    birthplace: "Atlanta, Georgia, USA", 
    traveled: [
      "Seoul, South Korea",
      "Boston, Massachusetts, USA",
      "San Diego, California, USA"
    ]
  }
};
---

<BaseLayout
  title={`${member.fullName} | Intelligent Biomechanics Lab`}
  description={`${member.fullName} profile page for the Intelligent Biomechanics Lab.`}
>
  <section id="member-profile">
    <div class="cs-container">

      <div class="cs-hero">
        <div class="cs-image-group">
          <img
            class="cs-profile-image"
            src={member.image}
            alt={member.fullName}
            width="500"
            height="600"
            loading="eager"
            decoding="async"
          />
        </div>

        <div class="cs-hero-content">
          <span class="cs-topper">Team Member Profile</span>
          <h1 class="cs-title">{member.fullName}</h1>
          <p class="cs-role">{member.role}</p>
          <p class="cs-short-bio">{member.shortBio}</p>

          <div class="cs-meta">
            <div class="cs-meta-item">
              <span class="cs-meta-label">Lab</span>
              <span class="cs-meta-value">{member.department}</span>
            </div>
            <div class="cs-meta-item">
              <span class="cs-meta-label">Email</span>
              <a class="cs-meta-value" href={`mailto:${member.email}`}>{member.email}</a>
            </div>
          </div>
        </div>
      </div>

      <div class="cs-main-grid">
        <div class="cs-main-content">
          <section class="cs-section-card">
            <h2>Introduction</h2>
            <p>{member.introduction}</p>
          </section>

          <section class="cs-section-card">
            <h2>Academic Experience</h2>
            <ul class="cs-list">
              {member.academicExperience.map((item) => (
                <li>{item}</li>
              ))}
            </ul>
          </section>

          <section class="cs-section-card">
            <h2>Work Experience</h2>
            <ul class="cs-list">
              {member.workExperience.map((item) => (
                <li>{item}</li>
              ))}
            </ul>
          </section>

          <section class="cs-section-card">
            <h2>CV Overview</h2>
            <div class="cs-cv-grid">
              {member.cvSections.map((section) => (
                <div class="cs-cv-card">
                  <h3>{section.title}</h3>
                  <ul class="cs-list">
                    {section.items.map((item) => (
                      <li>{item}</li>
                    ))}
                  </ul>
                </div>
              ))}
            </div>
          </section>

          <section class="cs-section-card">
            <h2>Map & Location Highlights</h2>
            <p class="cs-map-note">
              This section is prepared for the requested location points: high school, birthplace, and places traveled.
            </p>

            <div class="cs-map-placeholder">
              <div class="cs-map-placeholder-inner">
                <strong>Map Placeholder</strong>
                <p>
                  Placeholder.
                </p>
              </div>
            </div>

            <div class="cs-location-grid">
              <div class="cs-location-card">
                <h3>Birthplace</h3>
                <p>{member.locations.birthplace}</p>
              </div>

              <div class="cs-location-card">
                <h3>Places Travelled</h3>
                <ul class="cs-list">
                  {member.locations.traveled.map((place) => (
                    <li>{place}</li>
                  ))}
                </ul>
              </div>
            </div>
          </section>
        </div>

        <aside class="cs-sidebar">
          <div class="cs-sidebar-card">
            <h3>Quick Facts</h3>
            <ul class="cs-facts-list">
              <li>
                <span>Name</span>
                <strong>{member.fullName}</strong>
              </li>
              <li>
                <span>Role</span>
                <strong>{member.role}</strong>
              </li>
              <li>
                <span>Lab</span>
                <strong>{member.department}</strong>
              </li>
            </ul>
          </div>

          <div class="cs-sidebar-card">
            <h3>Hobbies</h3>
            <p>
              <ul class="cs-list">
                <li>Puerto Rico</li>
                <li>Florida</li>
            </ul>

        </aside>
      </div>
    </div>
  </section>
</BaseLayout>

<style lang="less">
  #member-profile {
    padding-top: 8rem;
    padding-bottom: var(--sectionPadding);

    .cs-container {
      width: 100%;
      max-width: (1280/16rem);
      margin: auto;
      display: flex;
      flex-direction: column;
      gap: (32/16rem);
    }

    .cs-breadcrumbs {
      font-size: (14/16rem);
      line-height: 1.5em;
      color: var(--bodyTextColor);

      a {
        color: var(--primary);
        text-decoration: none;
      }

      span {
        margin: 0 (6/16rem);
      }
    }

    .cs-hero {
      display: grid;
      grid-template-columns: 1fr;
      gap: (24/16rem);
      align-items: start;
    }

    .cs-image-group {
      width: 100%;
      max-width: (420/16rem);
    }

    .cs-profile-image {
      width: 100%;
      height: auto;
      display: block;
      border-radius: (16/16rem);
      border: 1px solid #e8e8e8;
      object-fit: cover;
    }

    .cs-hero-content {
      display: flex;
      flex-direction: column;
      gap: (12/16rem);
    }

    .cs-topper {
      font-size: (14/16rem);
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--primary);
    }

    .cs-title {
      font-size: clamp(2rem, 5vw, 3.25rem);
      line-height: 1.1em;
      margin: 0;
      color: var(--headerColor);
    }

    .cs-role {
      font-size: (20/16rem);
      font-weight: 700;
      margin: 0;
      color: var(--primary);
    }

    .cs-short-bio {
      font-size: (16/16rem);
      line-height: 1.7em;
      margin: 0;
      color: var(--bodyTextColor);
      max-width: 48rem;
    }

    .cs-meta {
      display: grid;
      grid-template-columns: 1fr;
      gap: (12/16rem);
      margin-top: (8/16rem);
    }

    .cs-meta-item {
      padding: (16/16rem);
      border: 1px solid #e8e8e8;
      border-radius: (12/16rem);
      background: #fafafa;
      display: flex;
      flex-direction: column;
      gap: (4/16rem);
    }

    .cs-meta-label {
      font-size: (13/16rem);
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      color: var(--bodyTextColor);
    }

    .cs-meta-value {
      font-size: (16/16rem);
      line-height: 1.5em;
      color: var(--headerColor);
      text-decoration: none;
    }

    .cs-main-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: (24/16rem);
    }

    .cs-main-content {
      display: flex;
      flex-direction: column;
      gap: (24/16rem);
    }

    .cs-section-card,
    .cs-sidebar-card {
      border: 1px solid #e8e8e8;
      border-radius: (16/16rem);
      padding: (24/16rem);
      background-color: #fff;
    }

    .cs-section-card h2,
    .cs-sidebar-card h3,
    .cs-cv-card h3,
    .cs-location-card h3 {
      margin-top: 0;
      color: var(--headerColor);
    }

    .cs-section-card p,
    .cs-sidebar-card p {
      line-height: 1.7em;
      color: var(--bodyTextColor);
    }

    .cs-list {
      margin: 0;
      padding-left: 1.25rem;

      li {
        margin-bottom: 0.5rem;
        line-height: 1.6em;
        color: var(--bodyTextColor);
      }
    }

    .cs-cv-grid,
    .cs-location-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: (16/16rem);
    }

    .cs-cv-card,
    .cs-location-card {
      border: 1px solid #ececec;
      border-radius: (12/16rem);
      padding: (18/16rem);
      background: #fafafa;
    }

    .cs-map-note {
      margin-bottom: (16/16rem);
    }

    .cs-map-placeholder {
      min-height: (280/16rem);
      border: 2px dashed #cfcfcf;
      border-radius: (16/16rem);
      background: #f7f7f7;
      display: flex;
      align-items: center;
      justify-content: center;
      text-align: center;
      margin-bottom: (20/16rem);
      padding: (24/16rem);
      box-sizing: border-box;
    }

    .cs-map-placeholder-inner p {
      margin: (8/16rem) 0 0 0;
    }

    .cs-sidebar {
      display: flex;
      flex-direction: column;
      gap: (24/16rem);
    }

    .cs-facts-list {
      list-style: none;
      padding: 0;
      margin: 0;
      display: flex;
      flex-direction: column;
      gap: (14/16rem);

      li {
        display: flex;
        flex-direction: column;
        gap: (4/16rem);
      }

      span {
        font-size: (13/16rem);
        text-transform: uppercase;
        letter-spacing: 0.06em;
        color: var(--bodyTextColor);
      }

      strong {
        color: var(--headerColor);
      }
    }
  }

  @media only screen and (min-width: 48rem) {
    #member-profile {
      .cs-hero {
        grid-template-columns: minmax(18rem, 26rem) 1fr;
        gap: (32/16rem);
      }

      .cs-meta {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }

      .cs-cv-grid,
      .cs-location-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }
    }
  }

  @media only screen and (min-width: 64rem) {
    #member-profile {
      .cs-main-grid {
        grid-template-columns: minmax(0, 2fr) minmax(18rem, 22rem);
        align-items: start;
      }

      .cs-sidebar {
        position: sticky;
        top: 6rem;
      }

      .cs-location-grid {
        grid-template-columns: repeat(3, minmax(0, 1fr));
      }
    }
  }
</style>